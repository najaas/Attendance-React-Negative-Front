{
  "cli": { "version": ">=3.0.0" },
  "build": {
    "preview": {
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://attendance-back-end.onrender.com/api",
        "EXPO_PUBLIC_API_FALLBACK_URLS": ""
      }
    },
    "dev": {
      "developmentClient": true,
      "android": { "buildType": "apk", "distribution": "internal" },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://attendance-back-end.onrender.com/api",
        "EXPO_PUBLIC_API_FALLBACK_URLS": ""
      }
    }
  }
}
